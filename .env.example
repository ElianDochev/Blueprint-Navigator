# Blueprint Navigator environment variables
# The app is frontend-only and stores data locally in the browser (IndexedDB).

# Host port for Docker Compose mapping.
# Container always serves Vite on 5173 internally.
# Example usage: APP_PORT=5173 docker compose up --build
APP_PORT=5174

# Optional runtime environment marker.
# Used by Docker Compose defaults; can remain as development.
NODE_ENV=development

# Optional temp directory inside container (already set in compose by default).
TMP_DIR=/app/tmp

# OpenAI API settings for LLM query parsing (dashboard + voice).
# IMPORTANT: In this frontend-only architecture, this key is exposed to the browser.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
VITE_OPENAI_WHISPER_MODEL=whisper-1
